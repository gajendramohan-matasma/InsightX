# Database
DATABASE_URL=postgresql+asyncpg://jd_analytics:jd_analytics_dev@localhost:5432/jd_financial_analytics

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Anaplan Integration
ANAPLAN_CLIENT_ID=your-anaplan-client-id
ANAPLAN_CLIENT_SECRET=your-anaplan-client-secret
ANAPLAN_API_BASE_URL=https://api.anaplan.com/2/0
ANAPLAN_AUTH_URL=https://us1a.app.anaplan.com/oauth/token

# PowerBI Integration
POWERBI_TENANT_ID=your-azure-tenant-id
POWERBI_CLIENT_ID=your-powerbi-app-client-id
POWERBI_CLIENT_SECRET=your-powerbi-app-client-secret

# Azure AD Authentication
AZURE_AD_TENANT_ID=your-azure-tenant-id
AZURE_AD_CLIENT_ID=your-azure-ad-app-client-id
AZURE_AD_AUDIENCE=api://jd-financial-analytics

# CORS
CORS_ORIGINS=http://localhost:5001

# Environment
ENVIRONMENT=development
